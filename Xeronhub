    btnMinus.Size             = UDim2.new(0, 18, 0, 18)
    btnMinus.Position         = UDim2.new(0.73, 0, 0.5, -9)
    btnMinus.BackgroundColor3 = C.BG_ROW
    btnMinus.Text             = "-"
    btnMinus.Font             = Enum.Font.GothamBold
    btnMinus.TextSize         = 13
    btnMinus.TextColor3       = C.MUTED
    btnMinus.AutoButtonColor  = false
    btnMinus.ZIndex           = 8
    Instance.new("UICorner", btnMinus).CornerRadius = UDim.new(1, 0)

    local btnPlus = Instance.new("TextButton", row)
    btnPlus.Size             = UDim2.new(0, 18, 0, 18)
    btnPlus.Position         = UDim2.new(1, -18, 0.5, -9)
    btnPlus.BackgroundColor3 = C.BG_ROW
    btnPlus.Text             = "+"
    btnPlus.Font             = Enum.Font.GothamBold
    btnPlus.TextSize         = 13
    btnPlus.TextColor3       = C.MUTED
    btnPlus.AutoButtonColor  = false
    btnPlus.ZIndex           = 8
    Instance.new("UICorner", btnPlus).CornerRadius = UDim.new(1, 0)

    local track = Instance.new("Frame", row)
    track.Size             = UDim2.new(0, 0, 0, 3)
    track.Visible          = false  -- скрыт, просто +/- кнопки

    local function updateVal(delta)
        local cur = Settings[cfg.key]
        local new = math.clamp(
            math.floor((cur + delta) / cfg.step + 0.5) * cfg.step,
            cfg.min, cfg.max
        )
        new = math.floor(new * 1000 + 0.5) / 1000
        Settings[cfg.key] = new
        valLbl.Text = tostring(new)
    end

    btnMinus.MouseButton1Click:Connect(function() updateVal(-cfg.step) end)
    btnPlus.MouseButton1Click:Connect(function() updateVal(cfg.step) end)

    table.insert(allSliderRows, { mode = mode, row = row })
    return row
end

