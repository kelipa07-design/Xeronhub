-- ПОИСК ЦЕЛИ (по любой части тела)
-- ══════════════════════════════════════════════════════════
local function getAimedTarget()
    local vpSize  = Camera.ViewportSize
    local unitRay = Camera:ScreenPointToRay(vpSize.X / 2, vpSize.Y / 2)
    local best, bestDot = nil, Settings.DOT_THRESH

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            for _, part in ipairs(p.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    local dir = (part.Position - Camera.CFrame.Position).Unit
                    local dot = unitRay.Direction:Dot(dir)
                    if dot > bestDot then
                        bestDot = dot
                        best    = p
                    end
                end
            end
        end
    end
    return best
end

