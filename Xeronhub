        for i, bb in ipairs(bbList) do
            local s1 = math.sin(i*1.7+0.3)*0.5+0.5
            local s2 = math.cos(i*2.3+0.7)*0.5+0.5
            local s3 = math.sin(i*3.1+1.1)*0.5+0.5
            local cnt = Settings.V2_CUBE_COUNT
            local aOff = i*(360/cnt)+s1*12
            local ang = math.rad(t*60*Settings.V2_ORBIT_SPEED+aOff)
            local or_ = hW+0.25+s3*0.15
            local ox = or_*math.cos(ang); local oz = or_*math.sin(ang)
            local bob = math.sin(t*0.05+i*0.3)*0.1
            local oy = s2*eH*1.05+bob
            bb.Size = UDim2.new(0,Settings.V2_CUBE_SIZE*60,0,Settings.V2_CUBE_SIZE*60)
            bb.StudsOffset = Vector3.new(ox, oy-eH/2, oz)
            local ct = ((i-1)/cnt + math.sin(t+i)*0.1)%1
            bb:FindFirstChildOfClass("Frame").BackgroundColor3 = gradColor(ct)
        end
    end)
