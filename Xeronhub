local v1Billboards = {}

local function removeV1(p)
    local d = v1Billboards[p]
    if d then
        if d.conn then d.conn:Disconnect() end
        if d.bb and d.bb.Parent then d.bb:Destroy() end
        v1Billboards[p] = nil
    end
end

local function createV1(p)
    if v1Billboards[p] then return end
    local char = p.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local bb = Instance.new("BillboardGui")
    bb.Name = "TESP_V1"; bb.Size = UDim2.new(0,140,0,200)
    bb.AlwaysOnTop = true; bb.Adornee = hrp; bb.Parent = gui

    local rings = {}
    local yOffsets = {-55, 0, 55}
    for k = 1, Settings.V1_RINGS do
        local dots = {}
        for j = 1, Settings.V1_TRAIL do
            local dot = Instance.new("Frame", bb)
            dot.Size = UDim2.new(0, Settings.V1_BASE_SIZE, 0, Settings.V1_BASE_SIZE)
            dot.BackgroundColor3 = gradColor((k-1)/Settings.V1_RINGS)
            dot.BackgroundTransparency = 0.3
            dot.BorderSizePixel = 0; dot.ZIndex = 50
            Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
            table.insert(dots, dot)
        end
        rings[k] = { dots=dots, yOff=yOffsets[k] }
    end

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then removeV1(p); return end
        local t = tick() * Settings.V1_SPEED
        local cx = bb.AbsoluteSize.X/2; local cy = bb.AbsoluteSize.Y/2
        for k, rd in ipairs(rings) do
            for j = 1, Settings.V1_TRAIL do
                local kf = j/Settings.V1_TRAIL
                local angle = math.rad(k*120 + (t*50 - j*10) % 360)
                local r = Settings.V1_RADIUS*(1-kf*0.3)
                local ox = math.cos(angle)*r; local oy = math.sin(angle)*r*0.4
                local sz = math.max(2, Settings.V1_BASE_SIZE*(1-kf*0.7))
                local dot = rd.dots[j]
                dot.Size = UDim2.new(0,sz,0,sz)
                dot.Position = UDim2.new(0, cx+ox-sz/2, 0, cy+rd.yOff+oy-sz/2)
                dot.BackgroundTransparency = 0.1 + kf*0.75
                dot.BackgroundColor3 = gradColor(((k-1)/Settings.V1_RINGS + kf*0.4)%1)
            end
        end
    end)
    v1Billboards[p] = { bb=bb, conn=conn }
end

