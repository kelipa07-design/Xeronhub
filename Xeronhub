-- CRYSTAL — кристаллы летящие по орбите
-- ══════════════════════════════════════════════════════════
local crystalData = {}

local function removeCrystal(p)
    local d = crystalData[p]
    if d then
        if d.conn then d.conn:Disconnect() end
        for _, bb in ipairs(d.bbs or {}) do if bb and bb.Parent then bb:Destroy() end end
        crystalData[p] = nil
    end
end

local function createCrystal(p)
    if crystalData[p] then return end
    local char = p.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local count = Settings.CRYSTAL_COUNT
    local bbList = {}

    for i = 1, count do
        -- Каждый кристалл = 3 BillboardGui (верх / тело / низ) для имитации формы
        local parts = {}
        local sizes = { 6, 10, 6 }   -- верх, тело, низ
        local yOffs = { 0.18, 0, -0.18 }

        for k = 1, 3 do
            local bb = Instance.new("BillboardGui")
            bb.Name = "TESP_Crystal_"..i.."_"..k
            local sz = sizes[k] * Settings.CRYSTAL_SIZE
            bb.Size = UDim2.new(0, sz, 0, sz * (k==2 and 2.5 or 1))
            bb.AlwaysOnTop = true; bb.Adornee = hrp; bb.Parent = gui

            local face = Instance.new("Frame", bb)
            face.Size = UDim2.new(1,0,1,0)
            local brightness = (k==1) and 0.1 or (k==2) and 0.2 or 0.5
            face.BackgroundTransparency = brightness
            face.BorderSizePixel = 0; face.ZIndex = 50

            -- Форма кристалла через UICorner
            local corner = Instance.new("UICorner", face)
            corner.CornerRadius = (k==2) and UDim.new(0,2) or UDim.new(0,6)

            face.BackgroundColor3 = gradColor((i-1)/count + (k-1)*0.1)
            table.insert(parts, { bb=bb, yOff=yOffs[k] })
        end

        -- Свечение (большой полупрозрачный круг)
        local glowBB = Instance.new("BillboardGui")
        glowBB.Name = "TESP_Crystal_"..i.."_glow"
        glowBB.Size = UDim2.new(0, 22*Settings.CRYSTAL_SIZE, 0, 22*Settings.CRYSTAL_SIZE)
        glowBB.AlwaysOnTop = true; glowBB.Adornee = hrp; glowBB.Parent = gui
        local gf = Instance.new("Frame", glowBB)
        gf.Size = UDim2.new(1,0,1,0)
        gf.BackgroundColor3 = gradColor((i-1)/count)
        gf.BackgroundTransparency = 0.75
        gf.BorderSizePixel = 0; gf.ZIndex = 49
        Instance.new("UICorner", gf).CornerRadius = UDim.new(1,0)
        table.insert(parts, { bb=glowBB, yOff=0 })

        table.insert(bbList, { parts=parts, idx=i })
    end

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then removeCrystal(p); return end

        local t = tick() * (Settings.CRYSTAL_SPEED * 0.05)
        local cnt = Settings.CRYSTAL_COUNT
        local eH = 5; local eW = 2; local hW = eW*0.5

        for _, cdata in ipairs(bbList) do
            local i = cdata.idx
            local s1 = math.sin(i*1.7+0.3)*0.5+0.5
            local s2 = math.cos(i*2.3+0.7)*0.5+0.5
            local s3 = math.sin(i*3.1+1.1)*0.5+0.5

            local aOff = math.rad(i*(360/cnt) + s1*12)
            local angle = t * Settings.CRYSTAL_SPEED + aOff
            local radius = hW + 0.25 + s3*0.15

            local ox = radius * math.cos(angle)
            local oz = radius * math.sin(angle)
            local oy = s2 * eH * 1.05

            -- Вращение самого кристалла
            local crystalRot = t * 3 + i * 0.5

            for _, part in ipairs(cdata.parts) do
                local poy = oy + part.yOff * Settings.CRYSTAL_SIZE * 2
                part.bb.StudsOffset = Vector3.new(ox, poy - eH/2, oz)
                -- Пульсация прозрачности свечения
                if part.bb.Name:find("glow") then
                    part.bb:FindFirstChildOfClass("Frame").BackgroundTransparency =
                        0.65 + math.sin(t*4 + i)*0.1
                end
                -- Пульсация цвета
                local ct = ((i-1)/cnt + math.sin(t*2+i)*0.15)%1
                part.bb:FindFirstChildOfClass("Frame").BackgroundColor3 = gradColor(ct)
            end
        end
    end)

    crystalData[p] = { bbs=bbList, conn=conn }
end

