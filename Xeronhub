local lastAimed = nil

RunService.Heartbeat:Connect(function()
    if not moduleEnabled["Target ESP"] then
        for p in pairs(v1Billboards) do removeV1(p) end
        for p in pairs(v2Data)        do removeV2(p) end
        for p in pairs(atomData)      do removeAtom(p) end
        for p in pairs(crystalData)   do removeCrystal(p) end
        lastAimed = nil
        return
    end

    local aimed = getAimedTarget()

    if lastAimed and lastAimed ~= aimed then
        removeAllESP(lastAimed)
    end

    if aimed then
        local mode = Settings.ESP_MODE
        if mode == "V1" then
            removeV2(aimed); removeAtom(aimed); removeCrystal(aimed); createV1(aimed)
        elseif mode == "V2" then
            removeV1(aimed); removeAtom(aimed); removeCrystal(aimed); createV2(aimed)
        elseif mode == "Atom" then
            removeV1(aimed); removeV2(aimed); removeCrystal(aimed); createAtom(aimed)
        elseif mode == "Crystal" then
            removeV1(aimed); removeV2(aimed); removeAtom(aimed); createCrystal(aimed)
        end
    end

    lastAimed = aimed
end)

