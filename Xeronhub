iconBtn.ImageRectOffset = Vector2.new(764,244); iconBtn.ImageRectSize = Vector2.new(36,36)
iconBtn.ImageColor3 = C.ACCENT1; iconBtn.ZIndex = 21
Instance.new("UICorner", iconBtn).CornerRadius = UDim.new(1,0)

local iconStroke = Instance.new("UIStroke", iconBtn)
iconStroke.Color = C.ACCENT1; iconStroke.Thickness = 2

-- ── ОТКРЫТИЕ / ЗАКРЫТИЕ ──────────────────────────────────
local isOpen  = false
local OPEN_P  = UDim2.new(0.5,-MENU_W/2, 0.5,-MENU_H/2)
local CLOSE_P = UDim2.new(0.5,0, 0.5,0)

local function toggleGui()
    isOpen = not isOpen
    if isOpen then
        shadow.Visible = true; main.Visible = true
        main.Size = UDim2.new(0,0,0,0); main.Position = CLOSE_P
        tween(main, { Size=UDim2.new(0,MENU_W,0,MENU_H), Position=OPEN_P }, 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        tween(shadow, { ImageTransparency=0.6 }, 0.45)
        tween(blur, { Size=18 }, 0.45)
        tween(iconBtn, { Rotation=90, ImageColor3=C.ACCENT2 }, 0.35)
        tween(iconStroke, { Color=C.ACCENT2 }, 0.35)
    else
        tween(main, { Size=UDim2.new(0,0,0,0), Position=CLOSE_P }, 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        tween(shadow, { ImageTransparency=1 }, 0.3)
        tween(blur, { Size=0 }, 0.3)
        tween(iconBtn, { Rotation=0, ImageColor3=C.ACCENT1 }, 0.3)
        tween(iconStroke, { Color=C.ACCENT1 }, 0.3)
        task.delay(0.32, function()
            if not isOpen then main.Visible = false; shadow.Visible = false end
        end)
    end
end

iconBtn.MouseButton1Click:Connect(toggleGui)
iconBtn.MouseEnter:Connect(function() tween(iconBtn, { BackgroundColor3=Color3.fromHex("#1a0f15") }, 0.2) end)
iconBtn.MouseLeave:Connect(function() tween(iconBtn, { BackgroundColor3=C.BG_MAIN }, 0.2) end)

-- ── DRAG ─────────────────────────────────────────────────
local dragging, dragStart, startPos
main.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = inp.Position; startPos = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
        local d = inp.Position - dragStart
        main.Position   = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
        shadow.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X-20, startPos.Y.Scale, startPos.Y.Offset+d.Y-20)
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
