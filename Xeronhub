-- ATOM — три вращающихся кольца с точками
-- ══════════════════════════════════════════════════════════
local atomData = {}

local function removeAtom(p)
    local d = atomData[p]
    if d then
        if d.conn then d.conn:Disconnect() end
        for _, bb in ipairs(d.bbs or {}) do if bb and bb.Parent then bb:Destroy() end end
        atomData[p] = nil
    end
end

local function createAtom(p)
    if atomData[p] then return end
    local char = p.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local rings    = Settings.ATOM_RINGS
    local segments = Settings.ATOM_SEGMENTS
    local bbList   = {}

    -- Для каждого кольца создаём сегментные точки + 6 маленьких «электронов»
    for ring = 1, rings do
        -- сегменты кольца
        for j = 1, segments do
            local bb = Instance.new("BillboardGui")
            bb.Name = "TESP_Atom_R"..ring.."S"..j
            bb.Size = UDim2.new(0, 5, 0, 5)
            bb.AlwaysOnTop = true; bb.Adornee = hrp; bb.Parent = gui
            local dot = Instance.new("Frame", bb)
            dot.Size = UDim2.new(1,0,1,0)
            dot.BackgroundColor3 = gradColor((ring-1)/rings)
            dot.BackgroundTransparency = 0.25
            dot.BorderSizePixel = 0; dot.ZIndex = 50
            Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
            table.insert(bbList, { bb=bb, ring=ring, seg=j, isElectron=false })
        end
        -- электроны (6 штук на кольцо)
        for e = 1, 6 do
            local bb = Instance.new("BillboardGui")
            bb.Name = "TESP_Atom_R"..ring.."E"..e
            bb.Size = UDim2.new(0, 10, 0, 10)
            bb.AlwaysOnTop = true; bb.Adornee = hrp; bb.Parent = gui
            local dot = Instance.new("Frame", bb)
            dot.Size = UDim2.new(1,0,1,0)
            dot.BackgroundColor3 = gradColor((ring-1)/rings + 0.15)
            dot.BackgroundTransparency = 0.0
            dot.BorderSizePixel = 0; dot.ZIndex = 51
            Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
            table.insert(bbList, { bb=bb, ring=ring, seg=e, isElectron=true })
        end
    end

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then removeAtom(p); return end
        local t      = tick() * Settings.ATOM_SPEED
        local radius = Settings.ATOM_RADIUS
        local eH     = 3  -- вертикальный центр

        for _, entry in ipairs(bbList) do
            local ring = entry.ring
            local ringOffsetDeg = (ring-1) * (180/rings)  -- наклон плоскости кольца
            local cosTilt = math.cos(math.rad(ringOffsetDeg))
            local sinTilt = math.sin(math.rad(ringOffsetDeg))

            if entry.isElectron then
                -- электрон движется по кольцу
                local eAngle = math.rad(t * 60 * (ring*0.5+1) + entry.seg * (360/6))
                local rx = math.cos(eAngle) * radius
                local ry_flat = math.sin(eAngle) * radius
                -- наклон кольца
                local ry = ry_flat * cosTilt
                local rz = ry_flat * sinTilt
                entry.bb.StudsOffset = Vector3.new(rx, ry + eH, rz)
                -- пульсация цвета
                local ct = ((ring-1)/rings + math.abs(math.sin(t*2+entry.seg)))%1
                entry.bb:FindFirstChildOfClass("Frame").BackgroundColor3 = gradColor(ct)
            else
                -- точка кольца (статично относительно угла, вращается)
                local baseAngle = math.rad(t * 30 * ring + (entry.seg/segments)*360)
                local rx = math.cos(baseAngle) * radius
                local ry_flat = math.sin(baseAngle) * radius
                local ry = ry_flat * cosTilt
                local rz = ry_flat * sinTilt
                entry.bb.StudsOffset = Vector3.new(rx, ry + eH, rz)
                local ct = ((ring-1)/rings + entry.seg/segments*0.3)%1
                local alp = 0.3 + math.abs(math.sin(baseAngle))*0.4
                entry.bb:FindFirstChildOfClass("Frame").BackgroundTransparency = alp
                entry.bb:FindFirstChildOfClass("Frame").BackgroundColor3 = gradColor(ct)
            end
        end
    end)
    atomData[p] = { bbs=bbList, conn=conn }
end

